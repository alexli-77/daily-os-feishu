# Model provider.
OPENAI_API_KEY=

# Feishu output and feedback target chat.
LARK_APP_ID=
LARK_APP_SECRET=
FEISHU_CHAT_ID=

# Optional owner for Feishu websocket interaction. Use a Feishu/Lark open_id.
FEISHU_OWNER_OPEN_ID=

# Optional GitHub data source.
GITHUB_TOKEN=

# Optional Linear data source.
LINEAR_API_KEY=

# Optional remote vault-gate data source.
VAULT_GATE_URL=
VAULT_GATE_TOKEN=

# Optional Codex override. Configure these in Setup -> Codex when the UI cannot
# find or authenticate the customer's local Codex CLI automatically.
CODEX_BIN=codex
CODEX_HOME=

# Local timezone used by Node and some child processes.
TZ=America/Toronto
