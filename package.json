{
  "name": "daily-os-feishu",
  "version": "0.1.0-alpha.0",
  "description": "Feishu-first local Daily OS agent for Mac.",
  "type": "module",
  "bin": {
    "daily-os-feishu": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts start",
    "ui": "tsx src/index.ts ui",
    "ui:open": "tsx src/index.ts ui open",
    "setup": "tsx src/index.ts setup",
    "doctor": "tsx src/index.ts doctor",
    "plan": "tsx src/index.ts plan",
    "review": "tsx src/index.ts review",
    "weekly": "tsx src/index.ts weekly",
    "collect": "tsx src/index.ts collect",
    "chrome:collect": "tsx src/index.ts chrome collect",
    "chat": "tsx src/index.ts chat",
    "progress": "tsx src/index.ts progress",
    "progress:confirm": "tsx src/index.ts progress confirm",
    "feedback:poll": "tsx src/index.ts feedback poll",
    "interaction:feishu": "tsx src/index.ts interaction feishu",
    "service:install": "tsx src/index.ts service install",
    "service:uninstall": "tsx src/index.ts service uninstall",
    "mac:companion:build": "bash scripts/build-mac-companion.sh",
    "mac:companion:run": "bash scripts/build-mac-companion.sh --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "privacy:scan": "bash scripts/privacy-scan.sh",
    "regression:test": "tsx scripts/regression-tests.ts",
    "alpha:smoke": "bash scripts/alpha-smoke.sh",
    "alpha:smoke:ci": "DAILY_OS_SKIP_AGENT_SMOKE=1 bash scripts/alpha-smoke.sh",
    "verify": "npm run typecheck && npm run build && npm run privacy:scan && npm run regression:test"
  },
  "keywords": [
    "daily-os",
    "feishu",
    "lark",
    "interaction",
    "codex",
    "vault",
    "personal-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "js-yaml": "^4.1.0",
    "openai": "^4.104.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
